:root {
  --bg-obsidian: #030712;       /* Mandatory background */
  --bg-surface: #0B1117;        /* Cards and panels */
  --border-slate: #1F2937;      /* All borders */
  --accent-cyan: #38BDF8;       /* Active states, highlights */
  --accent-indigo: #818CF8;     /* Secondary overlays */
  --text-primary: #F9FAFB;      /* Main text */
  --text-muted: #6B7280;        /* Subdued text */
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  background-color: var(--bg-obsidian);
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  height: 100vh;
  overflow: hidden; /* No page scroll — everything fits in viewport */
}

/* Leaflet map fix — must be explicit height */
.leaflet-container {
  width: 100%;
  height: 100%;
  background: #030712 !important;
}

/* Glassmorphism card style */
.glass-card {
  background: rgba(11, 17, 23, 0.8);
  border: 1px solid var(--border-slate);
  backdrop-filter: blur(8px);
  border-radius: 8px;
}

/* Cyan glow on active elements */
.cyan-glow {
  box-shadow: 0 0 8px rgba(56, 189, 248, 0.4);
  border-color: var(--accent-cyan) !important;
}

/* Scrollable sidebar content */
.sidebar-scroll {
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border-slate) transparent;
}
